@page "/Register"
@using DBL
@using Model
@using System.Threading.Tasks
@inject NavigationManager NavigationManager

<style>
    /* New Palette Applied:
           #9A3F3F - Primary (Deep Red)
           #C1856D - Secondary (Muted Rose)
           #E6CFA9 - Accent (Sandy Cream)
           #FBF9D1 - Background (Pale Yellow)
        */

    .register-container {
        max-width: 400px;
        margin: 50px auto;
        padding: 30px;
        background-color: #FBF9D1; /* Lightest shade for background */
        border-radius: 12px;
        border: 2px solid #E6CFA9; /* Sandy border */
        box-shadow: 0 8px 20px rgba(154, 63, 63, 0.15); /* Soft deep-red shadow */
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        direction: rtl;
        text-align: right;
        color: #9A3F3F; /* Deep red for text */
    }

    .register-header {
        text-align: center;
        margin-bottom: 25px;
        color: #9A3F3F;
        font-weight: 800;
        font-size: 1.8rem;
    }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            display: block;
            margin-bottom: 6px;
            color: #C1856D; /* Muted rose for labels */
            font-weight: 600;
        }

    .form-control {
        width: 100%;
        padding: 12px;
        background-color: #ffffff;
        border: 2px solid #E6CFA9;
        border-radius: 6px;
        box-sizing: border-box;
        transition: all 0.3s ease;
        color: #9A3F3F;
    }

        .form-control::placeholder {
            color: #C1856D;
            opacity: 0.6;
        }

        .form-control:focus {
            border-color: #9A3F3F;
            box-shadow: 0 0 8px rgba(154, 63, 63, 0.2);
            outline: none;
        }

    .btn-submit {
        width: 100%;
        padding: 14px;
        background-color: #9A3F3F; /* Primary Deep Red */
        color: #FBF9D1; /* Pale text on dark background */
        border: none;
        border-radius: 6px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        transition: background-color 0.3s, transform 0.1s;
        margin-top: 20px;
    }

        .btn-submit:hover {
            background-color: #C1856D; /* Switches to Muted Rose on hover */
        }

        .btn-submit:active {
            transform: scale(0.97);
        }

        .btn-submit:disabled {
            background-color: #E6CFA9;
            color: #C1856D;
            cursor: not-allowed;
        }

    .message-box {
        margin-top: 20px;
        padding: 12px;
        border-radius: 6px;
        text-align: center;
        font-weight: bold;
    }

    .msg-success {
        background-color: #E6CFA9;
        color: #9A3F3F;
        border: 1px solid #9A3F3F;
    }

    .msg-error {
        background-color: #9A3F3F;
        color: #FBF9D1;
        border: 1px solid #C1856D;
    }

    .login-link {
        display: block;
        margin-top: 10px;
        color: #C1856D;
        text-decoration: underline;
        font-size: 0.9rem;
    }
</style>

<div class="register-container">
    <h2 class="register-header">הרשמה לאתר</h2>

    <div class="form-group">
        <label>שם משתמש</label>
        <input type="text" class="form-control" @bind="username" placeholder="הכנס שם משתמש..." />
    </div>

    <div class="form-group">
        <label>אימייל</label>
        <input type="email" class="form-control" @bind="email" placeholder="הכנס כתובת אימייל..." />
    </div>

    <div class="form-group">
        <label>סיסמה</label>
        <input type="password" class="form-control" @bind="password" placeholder="הכנס סיסמה..." />
    </div>

    <button class="btn-submit" @onclick="RegisterUser" disabled="@isBusy">
        @if (isBusy)
        {
            <span>מעבד נתונים...</span>
        }
        else
        {
            <span>הרשם עכשיו</span>
        }
    </button>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="message-box @messageClass">
            @message
            <br />
            <a href="/Login" class="login-link">לחץ כאן להתחברות</a>
        </div>
    }
</div>

@code {
    private string username;
    private string email;
    private string password;
    private bool INSIDE = false;

    private string message = "";
    private string messageClass = "";
    private bool isBusy = false;

    private async Task RegisterUser()
    {
        message = "";
        isBusy = true;

        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            message = "נא למלא את כל השדות";
            messageClass = "msg-error";
            isBusy = false;
            return;
        }

        try
        {
            PlayerDB db = new PlayerDB();
            Player newPlayer = new Player
            {
                UserName = username,
                Email = email,
                IsAdmin = 0,
                Tokens = 0,
                ProfilePicture = null
            };

            Player result = await db.InsertAsync(newPlayer, password);

            if (result != null)
            {
                message = "המשתמש נרשם בהצלחה!";
                messageClass = "msg-success";
                username = string.Empty;
                email = string.Empty;
                password = string.Empty;
            }
            else
            {
                message = "שגיאה ביצירת המשתמש.";
                messageClass = "msg-error";
            }
        }
        catch (Exception ex)
        {
            message = "שגיאה: " + ex.Message;
            messageClass = "msg-error";
        }
        finally
        {
            isBusy = false;
        }
    }
}