@page "/Login"
@inject NavigationManager NavigationManager
@using Model
@using DBL
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage MySession
@inject Microsoft.AspNetCore.Components.NavigationManager navigationManager
@inject IJSRuntime js

<style>
    /* Cohesive Palette:
           #9A3F3F - Primary (Deep Red)
           #C1856D - Secondary (Muted Rose)
           #E6CFA9 - Accent (Sandy Cream)
           #FBF9D1 - Background (Pale Yellow)
        */

    .login-container {
        max-width: 400px;
        margin: 50px auto;
        padding: 30px;
        background-color: #FBF9D1; /* Light cream background */
        border-radius: 12px;
        border: 2px solid #E6CFA9; /* Sandy border */
        box-shadow: 0 8px 25px rgba(154, 63, 63, 0.1); /* Subtle deep red shadow */
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        direction: rtl;
        text-align: right;
        color: #9A3F3F; /* Primary text color */
    }

    .login-header {
        text-align: center;
        margin-bottom: 25px;
        color: #9A3F3F;
        font-weight: 800;
        font-size: 1.8rem;
    }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            display: block;
            margin-bottom: 6px;
            color: #C1856D; /* Muted rose for labels */
            font-weight: bold;
        }

    .form-control {
        width: 100%;
        padding: 12px;
        background-color: #ffffff;
        border: 2px solid #E6CFA9;
        color: #9A3F3F;
        border-radius: 6px;
        box-sizing: border-box;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #9A3F3F;
            box-shadow: 0 0 8px rgba(154, 63, 63, 0.2);
            outline: none;
        }

        .form-control::placeholder {
            color: #E6CFA9;
            opacity: 0.8;
        }

    .btn-submit {
        width: 100%;
        padding: 14px;
        background-color: #9A3F3F; /* Deep Red Button */
        color: #FBF9D1; /* Light text */
        border: none;
        border-radius: 6px;
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
        transition: background-color 0.3s, transform 0.1s;
        margin-top: 15px;
    }

        .btn-submit:hover {
            background-color: #C1856D; /* Switches to Rose on hover */
        }

        .btn-submit:active {
            transform: scale(0.97);
        }

        .btn-submit:disabled {
            background-color: #E6CFA9;
            color: #C1856D;
            opacity: 0.7;
            cursor: not-allowed;
        }

    .message-box {
        margin-top: 20px;
        padding: 15px;
        border-radius: 6px;
        text-align: center;
        font-weight: bold;
    }

    .msg-success {
        background-color: #E6CFA9;
        color: #9A3F3F;
        border: 2px solid #9A3F3F;
    }

    .msg-error {
        background-color: #9A3F3F;
        color: #FBF9D1;
        border: 2px solid #C1856D;
    }

    .forgot-link {
        display: block;
        margin-top: 15px;
        color: #C1856D;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s;
    }

        .forgot-link:hover {
            color: #9A3F3F;
            text-decoration: underline;
        }
</style>

<div class="login-container">
    <h2 class="login-header">כניסה למערכת</h2>

    <div class="form-group">
        <label>אימייל</label>
        <input type="email" class="form-control" @bind="email" placeholder="הכנס כתובת אימייל..." />
    </div>

    <div class="form-group">
        <label>סיסמה</label>
        <input type="password" class="form-control" @bind="password" placeholder="הכנס סיסמה..." />
    </div>

    <button class="btn-submit" @onclick="LoginUser" disabled="@isBusy">
        @if (isBusy)
        {
            <span>מתחבר...</span>
        }
        else
        {
            <span>התחבר</span>
        }
    </button>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="message-box @messageClass">
            @message
        </div>
    }

    <div style="text-align: center;">
        <a href="/Forgotpass" class="forgot-link">שכחתי סיסמה...</a>
    </div>
</div>

@code {
    private string email;
    private string password;
    private string message = "";
    private string messageClass = "";
    private bool isBusy = false;

    private async Task LoginUser()
    {
        message = "";
        isBusy = true;

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            message = "נא להזין אימייל וסיסמה";
            messageClass = "msg-error";
            isBusy = false;
            return;
        }

        try
        {
            PlayerDB db = new PlayerDB();
            Player result = await db.LoginAsync(email, password);

            if (result != null)
            {
                await MySession.SetAsync("Player", result);
                NavigationManager.NavigateTo("/Approved");
            }
            else
            {
                message = "אימייל או סיסמה שגויים.";
                messageClass = "msg-error";
            }
        }
        catch (Exception ex)
        {
            message = "שגיאה בהתחברות: " + ex.Message;
            messageClass = "msg-error";
        }
        finally
        {
            isBusy = false;
        }
    }
}