    private async Task UpdatePassword()
    {
        if (string.IsNullOrEmpty(newCode) || string.IsNullOrEmpty(newPassword))
        {
            message = "נא למלא את כל השדות";
            messageClass = "msg-error";
            return;
        }

        if (int.Parse(newCode) == numT)
        {
            PlayerDB db = new PlayerDB();
            Player player = new Player();
            player.Password = newPassword;
            player.TempCode = int.Parse(newCode);
            player.Email = email;
            int a = await db.UpdatePass2Async(player);

            if (a != 0)
            {
                message = "הסיסמה שונתה בהצלחה!";
                messageClass = "msg-success";
                THENERD = true;
                StateHasChanged();
            }
        }
        else
        {
            message = "קוד אימות שגוי!";
            messageClass = "msg-error";
        }
    }

private async Task GenerateResetToken()
{
    message = "";
    isBusy = true;

    if (string.IsNullOrWhiteSpace(email))
    {
        message = "נא להכניס כתובת אימייל";
        messageClass = "msg-error";
        isBusy = false;
        return;
    }

    try
    {
        PlayerDB db = new PlayerDB();
        var allPlayers = await db.GetAllAsync();

        // Find the player
        Player foundPlayer = allPlayers.FirstOrDefault(p => p.Email.ToLower() == email.ToLower());

        if (foundPlayer != null)
        {
            // SUCCESS PATH
            int num = random.Next(100000, 1000000);
            numT = num;
            foundPlayerT = foundPlayer;

            foundPlayer.TempCode = num;
            foundPlayer.DateCode = DateTime.Now;

            await db.UpdateTempCodeAsync(foundPlayer);

            IResend resend = ResendClient.Create("re_RM7v8VHD_LE95qwy9R2Do4qEWvs8QVmok");

            await resend.EmailSendAsync(new EmailMessage()
            {
                From = "Acme <onboarding@resend.dev>",
                To = foundPlayer.Email,
                Subject = "קוד אימות לאיפוס סיסמה",
                HtmlBody = $"<div style='direction:rtl; text-align:center;'><h3>קוד האימות שלך הוא:</h3><h1 style='color:#9A3F3F;'>{num}</h1></div>",
                ReplyTo = "onboarding@resend.dev",
            });

            // ONLY change the screen if the email was found and sent successfully
            message = "קוד לאיפוס סיסמה נשלח לאימייל שלך";
            messageClass = "msg-success";
            b = false;
        }
        else
        {
            // FAILURE PATH: User not found
            message = "כתובת האימייל אינה קיימת במערכת.";
            messageClass = "msg-error";
            b = true; // Force staying on the first screen
        }
    }
    catch (Exception ex)
    {
        message = "אירעה שגיאה: " + ex.Message;
        messageClass = "msg-error";
        b = true; // Stay on screen if there's a system error
    }
    finally
    {
        isBusy = false;
    }
}
