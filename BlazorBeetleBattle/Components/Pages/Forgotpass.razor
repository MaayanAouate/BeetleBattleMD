@page "/Forgotpass"
@using DBL
@using Model
@using System.Linq
@using Resend
@inject NavigationManager NavManager
@inject IJSRuntime js;

<style>
    /* Cohesive Palette:
           #9A3F3F - Primary (Deep Red)
           #C1856D - Secondary (Muted Rose)
           #E6CFA9 - Accent (Sandy Cream)
           #FBF9D1 - Background (Pale Yellow)
        */

    .forgot-container {
        max-width: 400px;
        margin: 50px auto;
        padding: 30px;
        background-color: #FBF9D1; /* Lightest shade */
        border-radius: 12px;
        border: 2px solid #E6CFA9; /* Sandy border */
        box-shadow: 0 10px 25px rgba(154, 63, 63, 0.12);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        direction: rtl;
        text-align: right;
        color: #9A3F3F; /* Deep red for text */
    }

    .forgot-header {
        text-align: center;
        margin-bottom: 20px;
        color: #9A3F3F;
        font-weight: 800;
        font-size: 1.6rem;
    }

    .info-text {
        font-size: 0.95em;
        margin-bottom: 25px;
        color: #C1856D; /* Muted rose for instructions */
        line-height: 1.5;
        text-align: center;
    }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            display: block;
            margin-bottom: 6px;
            color: #C1856D;
            font-weight: bold;
        }

    .form-control {
        width: 100%;
        padding: 12px;
        background-color: #ffffff;
        border: 2px solid #E6CFA9;
        border-radius: 8px;
        box-sizing: border-box;
        transition: all 0.3s ease;
        color: #9A3F3F;
    }

        .form-control::placeholder {
            color: #E6CFA9;
            opacity: 0.8;
        }

        .form-control:focus {
            border-color: #9A3F3F;
            box-shadow: 0 0 8px rgba(154, 63, 63, 0.2);
            outline: none;
        }

    .btn-submit {
        width: 100%;
        padding: 14px;
        background-color: #9A3F3F;
        color: #FBF9D1;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 15px;
    }

        .btn-submit:hover:not(:disabled) {
            background-color: #C1856D;
            transform: translateY(-2px);
        }

        .btn-submit:active {
            transform: scale(0.97);
        }

        .btn-submit:disabled {
            background-color: #E6CFA9;
            color: #C1856D;
            opacity: 0.7;
            cursor: not-allowed;
        }

    .message-box {
        margin-top: 25px;
        padding: 15px;
        border-radius: 8px;
        text-align: center;
        font-weight: bold;
        line-height: 1.4;
    }

    .msg-success {
        background-color: #E6CFA9;
        color: #9A3F3F;
        border: 1px solid #9A3F3F;
    }

    .msg-error {
        background-color: #9A3F3F;
        color: #FBF9D1;
        border: 1px solid #C1856D;
    }

    .login-nav-link {
        display: inline-block;
        margin-top: 10px;
        color: #9A3F3F;
        text-decoration: underline;
        font-weight: 800;
    }
</style>

@if (b)
{
    <div class="forgot-container">
        <h2 class="forgot-header">שחזור סיסמה</h2>

        <p class="info-text">הכנס את כתובת האימייל שלך ואנו נשלח לך קוד אימות לאיפוס הסיסמה.</p>

        <div class="form-group">
            <label>אימייל</label>
            <input type="email" class="form-control" @bind="email" placeholder="הכנס כתובת אימייל..." />
        </div>

        <button class="btn-submit" @onclick="GenerateResetToken" disabled="@isBusy">
            @if (isBusy)
            {
                <span>בודק נתונים...</span>
            }
            else
            {
                <span>שלח אימייל</span>
            }
        </button>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="message-box @messageClass">
                @message
            </div>
        }
    </div>
}
else
{
    <div class="forgot-container">
        <h2 class="forgot-header">אימות קוד</h2>

        <p class="info-text">הכנס את קוד האימות שנשלח אליך ואת הסיסמה החדשה שבחרת.</p>

        <div class="form-group">
            <label>קוד אימות</label>
            <input type="text" class="form-control" @bind="newCode" placeholder="הכנס קוד..." />
        </div>

        <div class="form-group">
            <label>סיסמה חדשה</label>
            <input type="password" class="form-control" @bind="newPassword" placeholder="הכנס סיסמה חדשה..." />
        </div>

        <button class="btn-submit" @onclick="UpdatePassword" disabled="@isBusy">
            @if (isBusy)
            {
                <span>מעדכן...</span>
            }
            else
            {
                <span>אפס סיסמה</span>
            }
        </button>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="message-box @messageClass">
                @message
                @if (THENERD)
                {
                    <br />
                    <a href="/Login" class="login-nav-link">לחץ כאן להתחברות</a>
                }
            </div>
        }
    </div>
}

