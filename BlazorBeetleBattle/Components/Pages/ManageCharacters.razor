@page "/ManageCharacters"
@using Model
@using DBL
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage MySession
@inject NavigationManager NavigationManager











@* 

@code{
    private Player currentPlayer;
    private string email;
    private string password;
    private string message = "";
    private string messageClass = "";
    private bool isBusy = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var result = await MySession.GetAsync<Player>("Player");
            if (result.Success && result.Value != null)
            {
                currentPlayer = result.Value;

                // 1. קודם טוענים את כל השמות מה-DB
                allCharacters = await charDb.GetAllAsync();

                // 2. אחר כך טוענים את הדמויות של השחקן
                await RefreshList();

                StateHasChanged();
            }
            else
            {
                NavigationManager.NavigateTo("/Login");
            }
        }
    }

    private async Task LoginUser()
    {

        message = "";
        isBusy = true;

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            message = "נא להזין אימייל וסיסמה";
            messageClass = "msg-error";
            isBusy = false;
            return;
        }

        try
        {
            PlayerDB db = new PlayerDB();
            Player result = await db.LoginAsync(email, password);

            if (result != null)
            {
                await MySession.SetAsync("Player", result);
                NavigationManager.NavigateTo("/Approved");
            }
            else
            {
                message = "שם משתמש או סיסמה שגויים.";
                messageClass = "msg-error";
            }
        }
        catch (Exception ex)
        {
            message = "שגיאה בהתחברות: " + ex.Message;
            messageClass = "msg-error";
        }
        finally
        {
            isBusy = false;
        }
    }
}
 *@


<div class="manager-wrapper">
    <div class="container">
        <h2>הדמויות שלי</h2>

        @if (allCharacters == null)
        {
            <p style="text-align:center;">טוען נתוני דמויות...</p>
        }
        else if (playerCharsList.Count == 0)
        {
            <p style="text-align:center;">אין לך דמויות כרגע.</p>
        }
        else
        {
            <table class="table-styled">
                <thead>
                    <tr>
                        <th>שם הדמות</th>
                        <th>רמה</th>
                        <th>כמות</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in playerCharsList)
                    {
                        <tr>
                            <td><strong>@GetCharacterName(item.CharacterID)</strong></td>
                            <td>@item.GetLevel()</td>
                            <td>@item.Counter</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private Player currentPlayer;
    private List<PlayerCharacters> playerCharsList = new();
    private List<Character> allCharacters;

    private PlayerCharactersDB playerCharDb = new();
    private CharacterDB charDb = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var result = await MySession.GetAsync<Player>("Player");
            if (result.Success && result.Value != null)
            {
                currentPlayer = result.Value;

                // 1. קודם טוענים את כל השמות מה-DB
                allCharacters = await charDb.GetAllAsync();

                // 2. אחר כך טוענים את הדמויות של השחקן
                await RefreshList();

                StateHasChanged(); 
            }
            else
            {
                NavigationManager.NavigateTo("/Login");
            }
        }
    }

    private async Task RefreshList()
    {
        playerCharsList = await playerCharDb.GetByPlayerIdAsync(currentPlayer.PlayerID);
    }

    private string GetCharacterName(int charId)
    {
        if (allCharacters == null) return "טוען...";

        var character = allCharacters.FirstOrDefault(c => c.CharacterID == charId);

        // אם מצאנו - מחזירים שם. אם לא - מחזירים את ה-ID כדי שנדע מה חסר ב-DB
        return character != null ? character.CharacterName : $"דמות לא מוכרת (ID: {charId})";
    }
}