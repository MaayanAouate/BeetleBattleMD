@page "/UpdateDetails"
@inject NavigationManager NavigationManager
@using Model
@using DBL
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage MySession
@inject Microsoft.AspNetCore.Components.NavigationManager navigationManager
@inject IJSRuntime js

<style>
    /* Cohesive Palette:
           #9A3F3F - Primary (Deep Red)
           #C1856D - Secondary (Muted Rose)
           #E6CFA9 - Accent (Sandy Cream)
           #FBF9D1 - Background (Pale Yellow)
        */

    .update-container {
        max-width: 450px;
        margin: 50px auto;
        padding: 35px;
        background-color: #FBF9D1; /* Light cream background */
        border-radius: 15px;
        border: 2px solid #E6CFA9; /* Sandy border */
        box-shadow: 0 10px 25px rgba(154, 63, 63, 0.12); /* Warm shadow */
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        direction: rtl;
        text-align: right;
        color: #9A3F3F; /* Deep red for text */
    }

    .update-header {
        text-align: center;
        margin-bottom: 25px;
        color: #9A3F3F;
        font-weight: 800;
        font-size: 1.6rem;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #C1856D; /* Muted rose for labels */
            font-weight: bold;
        }

    .form-control {
        width: 100%;
        padding: 12px;
        background-color: #ffffff;
        border: 2px solid #E6CFA9;
        border-radius: 8px;
        box-sizing: border-box;
        color: #9A3F3F;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #9A3F3F;
            box-shadow: 0 0 8px rgba(154, 63, 63, 0.2);
            outline: none;
        }

    .btn-submit {
        width: 100%;
        padding: 14px;
        background-color: #9A3F3F; /* Deep Red */
        color: #FBF9D1; /* Pale text */
        border: none;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 15px;
    }

        .btn-submit:hover:not(:disabled) {
            background-color: #C1856D;
            transform: translateY(-2px);
        }

        .btn-submit:active {
            transform: scale(0.97);
        }

        .btn-submit:disabled {
            background-color: #E6CFA9;
            color: #C1856D;
            opacity: 0.7;
            cursor: not-allowed;
        }

    .message-box {
        margin-top: 25px;
        padding: 12px;
        border-radius: 8px;
        text-align: center;
        font-weight: bold;
    }

    .msg-success {
        background-color: #E6CFA9;
        color: #9A3F3F;
        border: 1px solid #9A3F3F;
    }

    .msg-error {
        background-color: #9A3F3F;
        color: #FBF9D1;
        border: 1px solid #C1856D;
    }

    .loading-text {
        text-align: center;
        color: #C1856D;
        font-style: italic;
    }
</style>

<div class="update-container">
    <h2 class="update-header">עריכת פרטי חשבון</h2>

    @if (currentUser == null && !isLoaded)
    {
        <p class="loading-text">טוען נתונים...</p>
    }
    else
    {
        <div class="form-group">
            <label>שם משתמש</label>
            <input type="text" class="form-control" @bind="username" />
        </div>

        <div class="form-group">
            <label>אימייל</label>
            <input type="email" class="form-control" @bind="email" />
        </div>

        <div class="form-group">
            <label>סיסמה חדשה</label>
            <input type="password" class="form-control" @bind="password" />
        </div>

        <button class="btn-submit" @onclick="UpdateUserDetails" disabled="@isBusy">
            @if (isBusy)
            {
                <span>מעדכן...</span>
            }
            else
            {
                <span>שמור שינויים</span>
            }
        </button>
    }

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="message-box @messageClass">
            @message
        </div>
    }
</div>

@code {
    private Player currentUser;
    private string username;
    private string email;
    private string password;
    public Player p { get; set; } = null;

    private string message = "";
    private string messageClass = "";
    private bool isBusy = false;
    private bool isLoaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var player = await MySession.GetAsync<Player>("Player");
            if (player.Success && player.Value != null)
            {
                p = player.Value;
                StateHasChanged();
            }
            else
            {
                navigationManager.NavigateTo("/Login");
            }

            await LoadUserData();
        }
    }

    private async Task LoadUserData()
    {
        try
        {
            var result = await MySession.GetAsync<Player>("Player");
            if (result.Success && result.Value != null)
            {
                currentUser = result.Value;
                username = currentUser.UserName;
                email = currentUser.Email;
                password = currentUser.Password;
                isLoaded = true;
                StateHasChanged();
            }
            else
            {
                NavigationManager.NavigateTo("/Login");
            }
        }
        catch (Exception)
        {
            message = "שגיאה בטעינת נתוני משתמש";
            messageClass = "msg-error";
        }
    }

    private async Task UpdateUserDetails()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(email))
        {
            message = "נא למלא שדות חובה";
            messageClass = "msg-error";
            return;
        }

        isBusy = true;
        message = "";

        try
        {
            PlayerDB db = new PlayerDB();

            currentUser.UserName = username;
            currentUser.Email = email;
            currentUser.Password = password;

            int rowsAffected = await db.UpdateAsync(currentUser);
            await db.UpdatePassAsync(currentUser);

            if (rowsAffected > 0)
            {
                await MySession.SetAsync("Player", currentUser);
                message = "הפרטים עודכנו בהצלחה!";
                messageClass = "msg-success";
            }
            else
            {
                message = "לא בוצעו שינויים.";
                messageClass = "msg-error";
            }
        }
        catch (Exception ex)
        {
            message = "שגיאה: " + ex.Message;
            messageClass = "msg-error";
        }
        finally
        {
            isBusy = false;
        }
    }
}