@page "/"
@inject NavigationManager NavigationManager

<PageTitle>Home</PageTitle>

<center>
    <h1>this is the home page. hello!</h1>
    <h2>please choose your next action below</h2>

    <button class="Login" @onclick="Transfer1">
        Login
    </button>

    <button class="Register" @onclick="Transfer2">
        Sign up
    </button>


 @*    <a href="/Register" > dont have an account? sign up here! </a> *@
 @* דוגמה לקישור  *@
</center>>





@code {

    private void Transfer2()
    {
        NavigationManager.NavigateTo("/Register");
    }

    private void Transfer1()
    {
        NavigationManager.NavigateTo("/Login");
    }
}